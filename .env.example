# gooaye_pipeline Environment Variables
# Copy this file to .env and fill in your actual values
# IMPORTANT: Never commit .env to git - it contains sensitive keys

# === Transcription Providers ===
# At least one is required for transcription
GROQ_API_KEY=your_groq_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Optional: Delay between Groq API calls (default: 60 seconds)
GROQ_DELAY_SECONDS=60

# === Summarization Providers ===
# At least one is required for summarization
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
# GOOGLE_API_KEY is an alias for GEMINI_API_KEY

# === Social Media Publishing (Optional) ===

# LINE Notify
LINE_NOTIFY_TOKEN=your_line_notify_token_here

# Twitter/X
TWITTER_API_KEY=your_twitter_api_key_here
TWITTER_API_SECRET=your_twitter_api_secret_here
TWITTER_ACCESS_TOKEN=your_twitter_access_token_here
TWITTER_ACCESS_SECRET=your_twitter_access_secret_here

# Meta (Threads & Instagram)
META_ACCESS_TOKEN=your_meta_access_token_here
META_THREADS_USER_ID=your_threads_user_id_here
META_INSTAGRAM_USER_ID=your_instagram_user_id_here

# === Runtime Overrides (Optional) ===
# Override default podcast
PODCAST=gooaye

# Override summarization provider (default: gemini)
SUMMARY_PROVIDER=gemini

# Override whisper provider (default: groq)
WHISPER_PROVIDER=groq
