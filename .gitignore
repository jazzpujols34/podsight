# Virtual environment
venv/
.venv/
env/

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.so

# Data files - only gitignore large audio files
data/*/audio/
data/*/notifications/

# Keep transcripts and summaries (text files, needed for GitHub Actions)
# !data/*/transcripts/
# !data/*/summaries/

# Keep episodes.json (metadata only) for each podcast
!data/*/episodes.json

# Environment variables
.env
.env.local

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log

# Pipeline temp files
data/.pending_telegram.json
