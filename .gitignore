# Virtual environment
venv/
.venv/
env/

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.so

# Data files (large audio, transcripts, summaries)
# Each podcast has its own subdirectory under data/
data/*/audio/
data/*/transcripts/
data/*/summaries/
data/*/notifications/

# Keep episodes.json (metadata only) for each podcast
!data/*/episodes.json

# Environment variables
.env
.env.local

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log
