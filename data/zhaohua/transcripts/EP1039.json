    "start": 933.572,
    "end": 934.59204,
    "text": "我們都沒有辦法預設"
  },
  {
    "start": 934.59204,
    "end": 936.492,
    "text": "因為這是一個通膨的世界"
  },
  {
    "start": 936.492,
    "end": 938.77203,
    "text": "我們常常來分享說"
  },
  {
    "start": 938.77203,
    "end": 939.732,
    "text": "一定要理財"
  },
  {
    "start": 939.732,
    "end": 940.512,
    "text": "一定要投資"
  },
  {
    "start": 940.512,
    "end": 942.552,
    "text": "我想到了這個節骨眼"
  },
  {
    "start": 942.552,
    "end": 943.452,
    "text": "因為說實話"
  },
  {
    "start": 943.452,
    "end": 944.232,
    "text": "臺股非常的熱"
  },
  {
    "start": 944.232,
    "end": 945.112,
    "text": "美股也非常的熱"
  },
  {
    "start": 945.112,
    "end": 947.612,
    "text": "大家應該有全民覺醒的感覺"
  },
  {
    "start": 947.612,
    "end": 949.892,
    "text": "可是就是每一天都怕扣在最高點"
  },
  {
    "start": 949.892,
    "end": 951.292,
    "text": "可是股餘卻告訴你"
  },
  {
    "start": 951.292,
    "end": 952.552,
    "text": "你就怕不開始"
  },
  {
    "start": 952.552,
    "end": 954.012,
    "text": "那如果你自己不開始"
  },
  {
    "start": 954.012,
    "end": 955.992,
    "text": "你好歹從小朋友開始練習"
  },
  {
    "start": 955.992,
    "end": 956.552,
    "text": "也是好的"
  },
  {
    "start": 956.552,
    "end": 958.432,
    "text": "因為小朋友承受風險的時間"
  },
  {
    "start": 958.432,
    "end": 959.432,
    "text": "他可以比較長"
  },
  {
    "start": 959.432,
    "end": 960.33203,
    "text": "波動也可以比較大"
  },
  {
    "start": 960.33203,
    "end": 961.97205,
    "text": "那最保險的美股大盤"
  },
  {
    "start": 961.97205,
    "end": 962.71204,
    "text": "臺股大盤"
  },
  {
    "start": 962.71204,
    "end": 964.33203,
    "text": "那現在又多了這個"
  },
  {
    "start": 964.33203,
    "end": 966.192,
    "text": "正二來告訴你說"
  },
  {
    "start": 966.192,
    "end": 968.992,
    "text": "長期來看是不會扣血的"
  },
  {
    "start": 968.992,
    "end": 970.312,
    "text": "剛剛有把原因講了"
  },
  {
    "start": 970.312,
    "end": 971.392,
    "text": "因為有朋友問我"
  },
  {
    "start": 971.392,
    "end": 972.552,
    "text": "正二能不能長期存"
  },
  {
    "start": 972.552,
    "end": 973.692,
    "text": "也可以試試看"
  },
  {
    "start": 973.692,
    "end": 976.412,
    "text": "另外還有臺股的主動式的ETF"
  },
  {
    "start": 976.412,
    "end": 978.572,
    "text": "這一塊你今年還沒有打算"
  },
  {
    "start": 978.572,
    "end": 980.172,
    "text": "納入小朋友的持股嗎"
  },
  {
    "start": 980.172,
    "end": 983.65204,
    "text": "因為我們會從正二"
  },
  {
    "start": 983.65204,
    "end": 984.872,
    "text": "或是主動型中"
  },
  {
    "start": 984.872,
    "end": 986.432,
    "text": "兩個選一個就對了"
  },
  {
    "start": 986.432,
    "end": 987.492,
    "text": "壓歲錢沒那麼多"
  },
  {
    "start": 987.492,
    "end": 988.252,
    "text": "對對對"
  },
  {
    "start": 988.252,
    "end": 988.912,
    "text": "折一嘛"
  },
  {
    "start": 988.912,
    "end": 990.77203,
    "text": "那個老父親不能夠"
  },
  {
    "start": 990.77203,
    "end": 991.952,
    "text": "幫他補那麼多錢"
  },
  {
    "start": 991.952,
    "end": 992.452,
    "text": "對對對"
  },
  {
    "start": 992.452,
    "end": 993.97205,
    "text": "因為最終還是會跟人家跑走"
  },
  {
    "start": 993.97205,
    "end": 997.612,
    "text": "你搞不好就把人家拐回你家"
  },
  {
    "start": 997.612,
    "end": 999.132,
    "text": "這樣子也不錯"
  },
  {
    "start": 999.132,
    "end": 1000.27203,
    "text": "養女兒不就是"
  },
  {
    "start": 1000.27203,
    "end": 1001.012,
    "text": "對吧"
  },
  {
    "start": 1001.012,
    "end": 1002.33203,
    "text": "後來多半子"
  },
  {
    "start": 1002.33203,
    "end": 1003.132,
    "text": "多半個兒子"
  },
  {
    "start": 1003.132,
    "end": 1003.672,
    "text": "對對對"
  },
  {
    "start": 1003.672,
    "end": 1005.132,
    "text": "也是這樣講是沒錯"
  },
  {
    "start": 1005.132,
    "end": 1005.532,
    "text": "是"
  },
  {
    "start": 1005.532,
    "end": 1007.47205,
    "text": "所以每一年"
  },
  {
    "start": 1007.47205,
    "end": 1008.372,
    "text": "為什麼過年的時候"
  },
  {
    "start": 1008.372,
    "end": 1010.412,
    "text": "會跟古魚再來跟大家聊"
  },
  {
    "start": 1010.412,
    "end": 1011.692,
    "text": "他的消費人員進度"
  },
  {
    "start": 1011.692,
    "end": 1012.65204,
    "text": "因為古魚是一個"
  },
  {
    "start": 1012.65204,
    "end": 1014.59204,
    "text": "非常的紀律型的爸爸"
  },
  {
    "start": 1014.59204,
    "end": 1016.372,
    "text": "所以他做這件事情"
  },
  {
    "start": 1016.372,
    "end": 1017.612,
    "text": "每年我們看在眼裡"
  },
  {
    "start": 1017.612,
    "end": 1018.812,
    "text": "現在也告訴你"
  },
  {
    "start": 1018.812,
    "end": 1021.072,
    "text": "不是因為現在臺股在比較高檔"
  },
  {
    "start": 1021.072,
    "end": 1022.812,
    "text": "所以他的成效這麼好"
  },
  {
    "start": 1022.812,
    "end": 1024.692,
    "text": "中間不管有起有落"
  },
  {
    "start": 1024.692,
    "end": 1026.832,
    "text": "他都會在過完年的那一個禮拜"
  },
  {
    "start": 1026.832,
    "end": 1028.392,
    "text": "幫女兒做好這件事情"
  },
  {
    "start": 1028.392,
    "end": 1029.332,
    "text": "對所以"
  },
  {
    "start": 1029.332,
    "end": 1031.652,
    "text": "如果你自己沒有小朋友的"
  },
  {
    "start": 1031.652,
    "end": 1033.952,
    "text": "不妨把你自己當小朋友試試看"
  },
  {
    "start": 1033.952,
    "end": 1035.112,
    "text": "試試看"
  },
  {
    "start": 1035.112,
    "end": 1035.952,
    "text": "這樣的做法"
  },
  {
    "start": 1035.952,
    "end": 1037.272,
    "text": "其實風險沒有很高"
  },
  {
    "start": 1037.272,
    "end": 1038.512,
    "text": "其實風險沒有很高"
  },
  {
    "start": 1038.512,
    "end": 1039.112,
    "text": "可是會比"
  },
  {
    "start": 1039.112,
    "end": 1042.292,
    "text": "留在那種非常傳統保守的商品裡面的"
  },
  {
    "start": 1042.292,
    "end": 1043.3721,
    "text": "績效又再更好"
  },
  {
    "start": 1043.3721,
    "end": 1043.832,
    "text": "對沒有錯"
  },
  {
    "start": 1043.832,
    "end": 1045.612,
    "text": "好那我們今天的這個"
  },
  {
    "start": 1045.612,
    "end": 1047.732,
    "text": "趙懷餘古貨仔的新春特別版"
  },
  {
    "start": 1047.732,
    "end": 1048.512,
    "text": "就到這邊了"
  },
  {
    "start": 1048.512,
    "end": 1050.1321,
    "text": "跟各位聽眾朋友說拜拜咯"
  },
  {
    "start": 1050.1321,
    "end": 1050.432,
    "text": "拜拜"
  },
  {
    "start": 1050.432,
    "end": 1051.412,
    "text": "新年快樂"
  },
  {
    "start": 1051.412,
    "end": 1052.1321,
    "text": "新年快樂"
  },
  {
    "start": 1052.812,
    "end": 1057.812,
    "text": "by bwd6"
  }
]