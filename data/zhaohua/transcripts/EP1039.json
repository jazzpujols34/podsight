  {
    "start": 631.328,
    "end": 632.368,
    "text": "對耶"
  },
  {
    "start": 632.368,
    "end": 633.328,
    "text": "對因為券"
  },
  {
    "start": 633.328,
    "end": 634.748,
    "text": "因為正二的話"
  },
  {
    "start": 634.748,
    "end": 637.188,
    "text": "它是屬於槓桿型的產品"
  },
  {
    "start": 637.188,
    "end": 638.16797,
    "text": "信用型的產品"
  },
  {
    "start": 638.16797,
    "end": 639.848,
    "text": "那有一些券商的話"
  },
  {
    "start": 639.848,
    "end": 641.048,
    "text": "像信用型的產品"
  },
  {
    "start": 641.048,
    "end": 643.368,
    "text": "他可能要有融資融券的一個資格"
  },
  {
    "start": 643.368,
    "end": 645.068,
    "text": "那或者是說呢"
  },
  {
    "start": 645.068,
    "end": 646.428,
    "text": "你有信使用者的一個資格"
  },
  {
    "start": 646.428,
    "end": 647.588,
    "text": "然後要交易幾次"
  },
  {
    "start": 647.588,
    "end": 649.888,
    "text": "你才能夠去做佈局的一個動作"
  },
  {
    "start": 649.888,
    "end": 651.968,
    "text": "那當然每家券商的規定"
  },
  {
    "start": 651.968,
    "end": 653.628,
    "text": "可能會有點不太一樣"
  },
  {
    "start": 653.628,
    "end": 656.188,
    "text": "那如果說今天呢"
