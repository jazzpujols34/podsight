  {
    "start": 422.444,
    "end": 424.284,
    "text": "但是其實00850"
  },
  {
    "start": 424.284,
    "end": 425.844,
    "text": "它的價格也上來了"
  },
  {
    "start": 425.844,
    "end": 427.14398,
    "text": "你不是有00922"
  },
  {
    "start": 427.14398,
    "end": 429.404,
    "text": "00922是我個人的"
  },
  {
    "start": 429.404,
    "end": 431.664,
    "text": "那你可以換00922"
  },
  {
    "start": 431.664,
    "end": 433.70398,
    "text": "也不用"
  },
  {
    "start": 433.70398,
    "end": 434.76398,
    "text": "主動型的呢"
  },
  {
    "start": 434.76398,
    "end": 436.044,
    "text": "例如說985A"
